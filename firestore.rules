rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        getUserData().role == 'admin' || 
        request.auth.token.email == 'aksh1t04@gmail.com'
      );
    }

    function isMember() {
      return isSignedIn() && (getUserData().role == 'member' || getUserData().role == 'admin' || request.auth.token.email == 'aksh1t04@gmail.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string && data.uid.size() <= 128 &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['admin', 'member', 'viewer'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && 
                    isValidUser(incoming()) &&
                    incoming().role == 'member'; 
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) &&
                    isValidUser(incoming()) &&
                    (isAdmin() || incoming().role == existing().role);
    }

    // --- Projects ---
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.name is string && data.name.size() <= 200 &&
               data.status in ['active', 'on-hold', 'completed', 'cancelled'];
      }

      allow read: if isSignedIn();
      allow create: if isMember() && isValidProject(incoming());
      allow update: if isMember() && isValidProject(incoming());
      allow delete: if isAdmin();
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.title is string && data.title.size() <= 500 &&
               data.status in ['todo', 'in-progress', 'review', 'done'];
      }

      allow read: if isSignedIn();
      allow create: if isMember() && isValidTask(incoming());
      allow update: if isMember() && isValidTask(incoming());
      allow delete: if isMember();
    }

    // --- Clients ---
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isMember();
      allow update: if isMember();
      allow delete: if isAdmin();
    }

    // --- Invoices ---
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow create: if isMember();
      allow update: if isMember();
      allow delete: if isAdmin();
    }

    // --- Chat ---
    match /chat_rooms/{roomId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isMember() && incoming().text.size() <= 5000;
    }
  }
}
